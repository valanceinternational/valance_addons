<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══════════════════════════════════════════════════════════════
             LOGIN RESTRICTION CONFIG — Form View
        ════════════════════════════════════════════════════════════════ -->
        <record id="view_login_restriction_config_form" model="ir.ui.view">
            <field name="name">login.restriction.config.form</field>
            <field name="model">login.restriction.config</field>
            <field name="arch" type="xml">
                <form string="Login Restriction Configuration">

                    <sheet>
                        <!-- Live status banner -->
                        <div class="alert alert-warning mb-3" role="alert"
                             invisible="not is_restricted_now">
                            <i class="fa fa-lock me-2" title="Locked"/>
                            <strong>Restriction is ACTIVE right now.</strong>
                            Users in the restricted group cannot log in at this moment.
                        </div>
                        <div class="alert alert-success mb-3" role="alert"
                             invisible="is_restricted_now">
                            <i class="fa fa-unlock me-2" title="Unlocked"/>
                            <strong>Restriction is NOT active right now.</strong>
                            Restricted users can currently log in.
                        </div>

                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="e.g. Night Shift Restriction"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Restriction Window (IST)">
                                <field name="timezone"/>
                                <field name="restrict_start_time"
                                       widget="float_time"
                                       string="Blocked From"
                                       help="Enter time in HH:MM format. E.g. 20:00 = 8:00 PM"/>
                                <field name="restrict_end_time"
                                       widget="float_time"
                                       string="Blocked Until"
                                       help="Enter time in HH:MM format. E.g. 10:00 = 10:00 AM"/>
                                <field name="start_time_display" string="Start (display)" readonly="1"/>
                                <field name="end_time_display"   string="End (display)"   readonly="1"/>
                            </group>

                            <group string="Restricted Users &amp; Message">
                                <field name="active" widget="boolean_toggle"/>
                                <field name="restrict_group_id"
                                       string="Restricted User Group"
                                       help="All users in this group will be blocked during the window above."/>
                                <field name="restriction_message"
                                       string="Error Message Shown to User"/>
                            </group>
                        </group>

                        <group string="Live Status">
                            <field name="current_ist_time" string="Current Time" readonly="1"/>
                            <field name="is_restricted_now"
                                   string="Restriction Active Now?"
                                   readonly="1"
                                   widget="boolean"/>
                        </group>

                        <!-- Show members of the restricted group inline -->
                        <group string="Users Currently in Restricted Group" colspan="2">
                            <field name="restrict_group_id"
                                   readonly="1"
                                   widget="many2one"
                                   nolabel="1"
                                   invisible="not restrict_group_id">
                            </field>
                            <p class="text-muted" style="margin-left:8px;">
                                To add or remove users from the restricted group, go to
                                <strong>Settings → Users &amp; Companies → Groups</strong>
                                and edit the group directly, or open the user record and
                                change their groups.
                            </p>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             LOGIN RESTRICTION CONFIG — List View
        ════════════════════════════════════════════════════════════════ -->
        <record id="view_login_restriction_config_list" model="ir.ui.view">
            <field name="name">login.restriction.config.list</field>
            <field name="model">login.restriction.config</field>
            <field name="arch" type="xml">
                <list string="Login Restriction Configs" decoration-muted="active == False">
                    <field name="name"/>
                    <field name="restrict_group_id" string="Restricted Group"/>
                    <field name="start_time_display" string="Blocked From"/>
                    <field name="end_time_display"   string="Blocked Until"/>
                    <field name="timezone"           string="Timezone"/>
                    <field name="is_restricted_now"  string="Active Now?" widget="boolean"/>
                    <field name="active"             widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             ACTION
        ════════════════════════════════════════════════════════════════ -->
        <record id="action_login_restriction_config" model="ir.actions.act_window">
            <field name="name">Login Restriction Config</field>
            <field name="res_model">login.restriction.config</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No restriction configured yet!
                </p>
                <p>
                    Create a configuration to define <strong>which users</strong>
                    (by group) are blocked and <strong>during which hours</strong>.
                </p>
            </field>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             MENU  (under Settings → Technical or top-level)
        ════════════════════════════════════════════════════════════════ -->
        <menuitem
            id="menu_login_restriction_root"
            name="Login Restrictions"
            parent="base.menu_administration"
            sequence="100"/>

        <menuitem
            id="menu_login_restriction_config"
            name="Restriction Configuration"
            parent="menu_login_restriction_root"
            action="action_login_restriction_config"
            sequence="10"/>

        <!-- ═══════════════════════════════════════════════════════════════
             RES.USERS FORM — Add Allowed Apps field
        ════════════════════════════════════════════════════════════════ -->
        <record id="view_users_form_inherit_allowed_apps" model="ir.ui.view">
            <field name="name">res.users.form.inherit.allowed.apps</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='other_preferences']" position="inside">
                    <field name="allowed_menu_ids"
                           widget="many2many_tags"
                           string="Allowed Apps"
                           placeholder="Leave empty to allow all apps..."/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
