<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_template_form_view_tags_move" model="ir.ui.view">
        <field name="name">product.template.form.tags.move</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']//group[@name='extra_info']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[field[@name='qty_available']]" position="after">
                <label for="product_tag_ids"/>
                <div>
                    <field name="product_tag_ids" widget="many2many_tags"
                        context="{'product_template_id': id}"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
