<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Product Variant Form: change lst_price label to MRP -->
    <record id="product_normal_form_inherit_valance" model="ir.ui.view">
        <field name="name">product.product.form.inherit.valance</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='lst_price']" position="attributes">
                <attribute name="string">MRP</attribute>
            </xpath>
        </field>
    </record>

    <!-- Product Variant List: change Sales Price to MRP -->
    <record id="product_product_list_inherit_valance" model="ir.ui.view">
        <field name="name">product.product.list.inherit.valance</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lst_price']" position="attributes">
                <attribute name="string">MRP</attribute>
            </xpath>
        </field>
    </record>

    <!-- Product Variant Search: add part_number to existing name filter_domain -->
    <record id="product_product_search_inherit_valance" model="ir.ui.view">
        <field name="name">product.product.search.inherit.valance</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_search_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="filter_domain">['|', '|', '|', ('default_code', 'ilike', self), ('name', 'ilike', self), ('barcode', 'ilike', self), ('part_number', 'ilike', self)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
