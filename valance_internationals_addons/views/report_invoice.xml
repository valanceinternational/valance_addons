<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_valance" inherit_id="l10n_in.l10n_in_report_invoice_document_inherit">

        <!-- Compact table font -->
        <xpath expr="//table[@name='invoice_line_table']" position="attributes">
            <attribute name="style">font-size: 11px;</attribute>
        </xpath>

        <!-- Replace header with correct column order matching data cell order -->
        <xpath expr="//table[@name='invoice_line_table']/thead/tr" position="replace">
            <tr style="font-size: 10px;">
                <th class="text-center" rowspan="2" style="width:3%">Sr.</th>
                <th name="th_description" class="text-start" rowspan="2" style="width:22%">Product Name</th>
                <th class="text-center" rowspan="2"
                    t-if="o.company_id.account_fiscal_country_id.code == 'IN' and o.company_id.l10n_in_is_gst_registered"
                    style="width:7%">HSN/SAC<br/>Code</th>
                <th name="th_quantity" class="text-end" rowspan="2" style="width:5%">Qty</th>
                <th name="th_mrp" class="text-end" rowspan="2" style="width:8%">MRP</th>
                <th name="th_priceunit" class="text-end" rowspan="2" style="width:8%">Rate</th>
                <th name="th_discount" t-if="display_discount" class="text-end" rowspan="2" style="width:5%">Disc.%</th>
                <!-- Data order: td_taxes then td_subtotal, so header must match -->
                <th name="th_taxes" t-if="display_taxes" class="text-end" rowspan="2" style="width:5%">GST<br/>%</th>
                <th name="th_subtotal" class="text-end" rowspan="2" style="width:10%">Taxable<br/>Amount</th>
                <th class="text-center" colspan="2" style="width:14%">Tax Amount</th>
                <th name="th_net_amount" class="text-end" rowspan="2" style="width:10%">Net<br/>Amount</th>
            </tr>
            <tr style="font-size: 10px;">
                <th class="text-end">Central</th>
                <th class="text-end">State/UT</th>
            </tr>
        </xpath>

        <!-- Replace product description with Sr. + part_number-name -->
        <xpath expr="//td[@name='account_invoice_line_name']" position="replace">
            <td class="text-center" style="width:3%">
                <span t-out="line_index + 1"/>
            </td>
            <td name="account_invoice_line_name" t-att-class="padding_class" style="width:22%">
                <span t-if="line.product_id and line.product_id.part_number"
                      t-out="'%s-%s' % (line.product_id.part_number, line.product_id.name)"/>
                <span t-elif="line.product_id" t-field="line.product_id.name"/>
                <span t-else="" t-field="line.name" t-options="{'widget': 'text'}"/>
            </td>
        </xpath>

        <!-- Add MRP cell after Quantity -->
        <xpath expr="//td[@name='td_quantity']" position="after">
            <td name="td_mrp" class="text-end">
                <span t-if="line.product_id" class="text-nowrap"
                      t-out="line.product_id.lst_price"
                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
            </td>
        </xpath>

        <!-- Remove responsive class from Unit Price -->
        <xpath expr="//td[@name='td_price_unit']" position="attributes">
            <attribute name="t-attf-class">text-end</attribute>
        </xpath>

        <!-- Remove responsive class from Discount -->
        <xpath expr="//td[@name='td_discount']" position="attributes">
            <attribute name="t-attf-class">text-end</attribute>
        </xpath>

        <!-- Replace Taxes cell (comes BEFORE subtotal in data) to show GST % -->
        <xpath expr="//td[@name='td_taxes']" position="replace">
            <td name="td_taxes" t-if="display_taxes" class="text-end">
                <t t-set="gst_rate" t-value="sum(child.amount for tax in line.tax_ids for child in (tax.children_tax_ids or [tax]))"/>
                <span t-if="not hide_prices" t-out="str(round(gst_rate, 1)) + '%'"/>
            </td>
        </xpath>

        <!-- Add CGST, SGST, Net Amount AFTER subtotal (which is Taxable Amount) -->
        <xpath expr="//td[@name='td_subtotal']" position="after">
            <t t-set="line_cgst" t-value="sum(line.price_subtotal * child.amount / 100 for tax in line.tax_ids for child in (tax.children_tax_ids or [tax]) if child.l10n_in_gst_tax_type == 'cgst')"/>
            <t t-set="line_sgst" t-value="sum(line.price_subtotal * child.amount / 100 for tax in line.tax_ids for child in (tax.children_tax_ids or [tax]) if child.l10n_in_gst_tax_type == 'sgst')"/>
            <td class="text-end">
                <span t-if="not hide_prices" class="text-nowrap"
                      t-out="line_cgst"
                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
            </td>
            <td class="text-end">
                <span t-if="not hide_prices" class="text-nowrap"
                      t-out="line_sgst"
                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
            </td>
            <td class="text-end">
                <span t-if="not hide_prices" class="text-nowrap"
                      t-field="line.price_total"/>
            </td>
        </xpath>

        <!-- Remove HSN Summary section -->
        <xpath expr="//div[@name='l10n_in_hsn_summary']" position="replace">
            <div name="l10n_in_hsn_summary"/>
        </xpath>

        <!-- Fix Total amount in words styling -->
        <xpath expr="//p[contains(., 'Total amount in words')]" position="replace">
            <p class="text-end lh-sm" t-if="o.company_id.display_invoice_amount_total_words"
               style="border-top: 1px solid #dee2e6; padding-top: 4px; margin-top: 4px;">
                <strong>Total amount in words:</strong><br/>
                <span t-field="o.amount_total_words" style="font-size: 11px;"/>
            </p>
        </xpath>

    </template>
</odoo>
