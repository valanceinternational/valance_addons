<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_inherit_valance" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.valance</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="transfer_by"
                       invisible="picking_type_code != 'outgoing'"/>
                <field name="transfer_details"
                       invisible="picking_type_code != 'outgoing'"/>
            </xpath>
        </field>
    </record>
</odoo>
