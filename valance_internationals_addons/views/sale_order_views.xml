<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_valance" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.valance</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Hide base Send buttons -->
            <xpath expr="//button[@id='quotation_send_primary']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@id='quotation_send']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Custom Send button: changes state to 'sent' without email -->
            <xpath expr="//button[@id='quotation_send_primary']" position="before">
                <button
                    string="Send"
                    name="action_mark_as_sent"
                    type="object"
                    class="btn-primary"
                    data-hotkey="g"
                    invisible="state != 'draft'"/>
            </xpath>
            <xpath expr="//button[@id='quotation_send']" position="before">
                <button
                    string="Send"
                    name="action_mark_as_sent"
                    type="object"
                    data-hotkey="g"
                    invisible="state not in ('sent', 'sale')"/>
            </xpath>

            <xpath expr="//field[@name='commitment_date'][last()]" position="after">
                <field name="picking_date"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Order Summary" name="order_summary">
                    <group>
                        <field name="order_lines_summary"
                               widget="CopyClipboardText"
                               readonly="1"
                               nolabel="1"/>
                    </group>
                </page>
            </xpath>
	    <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
            	<field name="qty_on_hand"/>
            </xpath>

        </field>
    </record>
</odoo>
