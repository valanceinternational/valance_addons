<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="valance_internationals_addons.CopyClipboardTextField">
        <div class="d-flex flex-column">
            <textarea class="o_input o_field_text"
                      t-att-id="props.id"
                      readonly="readonly"
                      t-att-rows="6"
                      t-ref="textarea"
                      t-att-value="props.record.data[props.name] || ''"
            />
            <div class="d-flex gap-2 mt-2">
                <button class="btn btn-secondary btn-sm"
                        t-on-click="onCopyClick"
                        title="Copy as text"
                        type="button">
                    <i class="fa fa-clipboard me-1"/> Copy Text
                </button>
                <button class="btn btn-secondary btn-sm"
                        t-on-click="onCopyImageClick"
                        title="Copy as image (like Excel)"
                        type="button">
                    <i class="fa fa-image me-1"/> Copy as Image
                </button>
            </div>
        </div>
    </t>
</templates>
